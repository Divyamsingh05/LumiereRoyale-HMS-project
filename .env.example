# Server
# STRIPE_SECRET_KEY and STRIPE_PUBLISHABLE_KEY for Stripe integration (test keys ok)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Frontend (Vite) Stripe pub key (prefix VITE_ so client-side can access it)
VITE_STRIPE_PUBLISHABLE_KEY=

# SMTP (optional). If not provided, Ethereal test account will be used and credentials logged.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=no-reply@lumiere.local

# If frontend served from different origin, set CLIENT_ORIGIN (example: http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173
ADMIN_PASSWORD=change-me
REPORT_EMAIL=
REPORT_CRON_SCHEDULE=0 8 * * *
STRIPE_WEBHOOK_SECRET=
